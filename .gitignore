# ==============================================================================
# Python & Runtime (编译文件与虚拟环境)
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境 (兼容多种常见命名)
venv/
.venv/
env/

# 分发与构建
build/
dist/
*.egg-info/
.eggs/

# ==============================================================================
# Environment Variables & Secrets (关键安全配置)
# ==============================================================================
# 忽略所有 .env 文件，防止密钥泄露
.env
.env.*

# ❗ 必须保留 .env.example 作为配置模板
!.env.example

# ==============================================================================
# Testing & Code Quality (测试产物与缓存)
# ==============================================================================
# ⚠️ 注意：tests/ 源代码目录必须提交，此处仅忽略缓存和报告

# Pytest 缓存
.pytest_cache/

# Coverage 覆盖率报告
.coverage
.coverage.*
htmlcov/
coverage.xml

# Mypy 静态类型检查缓存
.mypy_cache/

# Ruff / Flake8 代码风格检查缓存
.ruff_cache/
.dmypy.json
dmypy.json

# Pre-commit 钩子缓存
.pre-commit-cache/

# ==============================================================================
# IDE & OS (编辑器配置与系统文件)
# ==============================================================================
# JetBrains (PyCharm)
.idea/

# VS Code（项目级配置按需提交，默认忽略）
.vscode/
*.code-workspace

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# ==============================================================================
# Application Specific (应用运行时产生的文件)
# ==============================================================================
# Loguru 日志文件
*.log
logs/

# ==============================================================================
# Database (本地数据库与 Alembic)
# ==============================================================================
# 本地临时数据库 (防止 SQLite 文件污染)
*.sqlite
*.sqlite3
*.db

# ⚠️ 严禁忽略 alembic/versions/*.py — 它们是数据库结构的版本历史！
# 仅忽略生成的临时 SQL 调试文件
*.sql

# ==============================================================================
# Docker
# ==============================================================================
# 如果本地挂载了 Docker 数据卷
.docker_volumes/

# ==============================================================================
# AI Agent & GSD 工作流 (Antigravity / Claude 工程化配置)
# ==============================================================================
# .claude/ 目录包含项目级 AI Skill 规范 → ✅ 必须提交（它是项目基建的一部分）
# .agent/ 目录包含 GSD 工作流引擎与配置 → ✅ 必须提交（它是团队协作标准）
# ⚠️ 但 .agent/scratch/ 是 AI 临时运行脚本的沙盒 → 🚫 严禁提交
.agent/scratch/

# .planning/ 包含代码地图等 GSD 自动分析产物 → 按需决定
# 如果你认为这是团队资产则提交；如果只是本地辅助可取消下面这行注释忽略它：
# .planning/

# ==============================================================================
# 依赖锁文件
# ==============================================================================
# uv.lock 是由 uv 依赖管理器生成的精确版本锁 → ✅ 必须提交
# 它保证了团队成员安装的依赖包版本完全一致（等效 poetry.lock / package-lock.json）
